{
  plugins: {
    ros2dds: {}
  },

  // Peer mode: connect to the Gazebo pod's zenoh router, with retry on failure
  mode: "peer",

  connect: {
    endpoints: [
      "tcp/gazebo-sim-zenoh:7447"
    ],
    retry: {
      period_init_ms: 1000,
      period_max_ms: 16000,
      period_increase_factor: 2
    },
    exit_on_failure: false
  },

  scouting: {
    multicast: {
      enabled: false
    }
  }
}
