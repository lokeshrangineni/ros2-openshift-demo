FROM osrf/ros:jazzy-simulation

ENV DEBIAN_FRONTEND=noninteractive \
    TURTLEBOT3_MODEL=waffle \
    ROS_DISTRO=jazzy \
    GZ_SIM_RESOURCE_PATH=/opt/ros/jazzy/share/nav2_minimal_tb3_sim/models:/opt/ros/jazzy/share/turtlebot3_gazebo/models

RUN apt-get update && apt-get install -y --no-install-recommends \
      ros-jazzy-navigation2 \
      ros-jazzy-nav2-bringup \
      ros-jazzy-nav2-minimal-tb3-sim \
      ros-jazzy-turtlebot3-gazebo \
      ros-jazzy-turtlebot3-simulations \
      ros-jazzy-teleop-twist-keyboard \
      mesa-utils \
      libgl1-mesa-dri \
      python3 \
      xvfb \
      x11vnc \
      novnc \
      websockify \
      openbox \
      xterm \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /tmp/.X11-unix && chmod 1777 /tmp/.X11-unix

WORKDIR /opt/ros2-demo

COPY entrypoint.sh /entrypoint.sh
COPY worlds/ /opt/ros2-demo/worlds/
COPY www/ /opt/ros2-demo/www/

RUN chmod +x /entrypoint.sh

EXPOSE 6080 8080

ENTRYPOINT ["/entrypoint.sh"]
